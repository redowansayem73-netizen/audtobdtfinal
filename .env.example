# Hostinger Node.js Environment Variables
# Copy these keys into your Hostinger Environment Variables panel
# DO NOT COMMIT ACTUAL SECRETS TO GIT

# Database Connection
DATABASE_URL=mysql://admin_user:YourStrongPassword123!@localhost:3306/audtobdt_db

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Email Configuration (for Nodemailer)
EMAIL_USER=your_email@audtobdt.com
EMAIL_PASS=your_email_app_password

# Server Port (Hostinger automatically provides this, but good to have)
PORT=3000

# Environment Mode
NODE_ENV=production
